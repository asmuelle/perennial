{
  "name": "perennial",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @perennial/web dev",
    "test": "vitest run",
    "e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm --filter @perennial/web build"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.0"
  }
}
